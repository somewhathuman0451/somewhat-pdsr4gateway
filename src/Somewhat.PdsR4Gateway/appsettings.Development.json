{
  "InboundAuth": {
    "JwtSigningKey": "local-dev-shared-signing-key-32-chars"
  },
  "PdsApi": {
    "BaseAddress": "http://localhost:5252/",
    "ApiKey": "local-dev-mock-api-key",
    "CertificateName": "default"
  },
  "SignedJwtClient": {
    "Audience": "mock-pds-api",
    "Scope": "pds.read"
  },
  "CertificateSource": {
    "DefaultCertificateName": "default",
    "Certificates": [
      {
        "Name": "default",
        "Source": "PemFiles",
        "CertificatePath": "../../samples/certs/dev-signing-cert.pem",
        "PrivateKeyPath": "../../samples/certs/dev-signing-key.pem"
      }
    ]
  },
  "GatewayAuth": {
    "EnableOidc": true,
    "OidcAuthority": "http://localhost:5020",
    "OidcClientId": "gateway-client",
    "OidcScope": "gateway.api",
    "RequireHttpsMetadata": false
  },
  "ApiQueueOptions": {
    "MaxTransactionsPerSecond": 5,
    "MaxConcurrentRequests": 1,
    "MaxQueueDepth": 200
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
